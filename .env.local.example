# ── Gemini (사진 분석) ─────────────────────────────────────────────
# https://aistudio.google.com 에서 발급한 API 키 (보통 AIza... 형식)
GEMINI_API_KEY=여기에_키를_넣으세요
# 선택: 사용할 모델 (기본값 gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ── Google Sheets (데이터 누적 저장) ───────────────────────────────
# 데이터를 저장할 스프레드시트 ID (URL 의 /d/ 와 /edit 사이 문자열)
GOOGLE_SHEETS_ID=
# 서비스 계정 이메일 (xxxx@yyyy.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# 서비스 계정 비공개 키. 줄바꿈은 \n 으로 한 줄로 만들고 큰따옴표로 감쌉니다.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
